\contentsline {figure}{\numberline {1}{\ignorespaces Comparaison entre une génération procédurale classique par bruit de Perlin (gauche) et un terrain soumis aux forces d'érosion (droite).}}{3}{figure.1}%
\contentsline {figure}{\numberline {2}{\ignorespaces Représentation conceptuelle du modèle des tuyaux virtuels gérant les échanges de flux bidimensionnels \cite {MDH07}.}}{5}{figure.2}%
\contentsline {figure}{\numberline {3}{\ignorespaces Organisation des textures GPU et correspondance avec les variables physiques du modèle d'érosion \cite {MDH07}.}}{5}{figure.3}%
\contentsline {figure}{\numberline {4}{\ignorespaces Comparaison géométrique du modèle des tuyaux virtuels appliqué à l'écoulement d'eau (voisinage de von Neumann à 4 directions, flèche bleue) et à l'éboulement thermique des sédiments (voisinage de Moore à 8 directions, flèche rouge).}}{6}{figure.4}%
\contentsline {figure}{\numberline {5}{\ignorespaces Mécanisme des tuyaux virtuels appliqué à l'érosion thermique. Les transferts de sédiments (flèches rouges) s'effectuent exclusivement vers les cellules voisines dont le dénivelé excède l'angle de talus local. À l'inverse, l'éboulement est mathématiquement inhibé (flèches jaunes) vers les zones considérées comme géologiquement stables.}}{7}{figure.5}%
\contentsline {figure}{\numberline {6}{\ignorespaces Architecture du double tamponnage : les passes physiques écrivent dans le tampon temporaire (WRITE), tandis que les passes de post-traitement rapatrient l'état final dans le tampon principal (READ), sous la protection des barrières mémoire.}}{7}{figure.6}%
